# 选择一个 LLM provider: anthropic | openai | deepseek
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 走 OpenAI 兼容接口（base_url=https://api.deepseek.com），不需要额外依赖
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 搜索：免费额度 https://app.tavily.com 注册获取
TAVILY_API_KEY=

# Langfuse tracing，免费额度 https://cloud.langfuse.com 注册获取
# 注意区域：注册时选的是 EU 还是 US，host 必须对应（EU: cloud.langfuse.com / US: us.cloud.langfuse.com），
# 选错区域 key 本身没错也会报 401 Unauthorized——去 Langfuse 项目设置页确认 API host 那一栏写的是什么。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# 反思循环最多重新搜索几轮，防止 LLM 自我批评不收敛导致死循环
MAX_RESEARCH_ITERATIONS=2
