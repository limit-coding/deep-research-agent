# 选择一个 LLM provider: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 搜索：免费额度 https://app.tavily.com 注册获取
TAVILY_API_KEY=

# Langfuse tracing，免费额度 https://cloud.langfuse.com 注册获取
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# 反思循环最多重新搜索几轮，防止 LLM 自我批评不收敛导致死循环
MAX_RESEARCH_ITERATIONS=2
